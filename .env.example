# OKX Developer Portal (web3.okx.com) — required for x402 facilitator
OKX_API_KEY=
OKX_SECRET_KEY=
OKX_PASSPHRASE=

# Wallet that receives USDT0 payments on X Layer (eip155:196)
PAY_TO=

# Set to "1" to disable payment gating during local development (no OKX creds yet)
PAYMENTS_DISABLED=

# Neon Postgres (jobs queue + demo rate limits)
DATABASE_URL=

# Local file storage for rendered MP4s + receipts, served via signed URLs
DATA_DIR=./data
FILES_SECRET=

# OpenAI — narration script (gpt-4o-mini) + TTS (gpt-4o-mini-tts)
OPENAI_API_KEY=

# Public base URL of the deployed service (used in receipts/status URLs)
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# TTS provider: "openai" (default) | "kokoro" (local, free)
TTS_PROVIDER=openai
